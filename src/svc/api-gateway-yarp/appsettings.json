{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-api": {
        "ClusterId": "auth",
        "Order": 20,
        "Match": {
          "Path": "/api/auth/{**catch-all}",
          "Methods": ["POST", "GET", "OPTIONS"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/auth" },
          { "PathPrefix": "/authentication" }
        ]
      },
      "auth-well-known": {
        "ClusterId": "auth",
        "Order": 20,
        "Match": {
          "Path": "/.well-known/{**catch-all}",
          "Methods": ["GET", "OPTIONS"]
        }
      },
      "auth-swagger": {
        "ClusterId": "auth",
        "Order": 5,
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },

      "storage-api": {
        "ClusterId": "storage",
        "Order": 20,
        "Match": {
          "Path": "/api/storage/{**catch-all}",
          "Methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/storage" },
          { "PathPrefix": "/wopi/files" }
        ]
      },
      "storage-api-root": {
        "ClusterId": "storage",
        "Order": 21,
        "Match": {
          "Path": "/api/storage",
          "Methods": ["GET", "OPTIONS"]
        },
        "Transforms": [
          { "PathSet": "/wopi/files" }
        ]
      },
      "storage-swagger": {
        "ClusterId": "storage",
        "Order": 5,
        "Match": {
          "Path": "/storage/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/storage" }
        ]
      },

      "lock-api": {
        "ClusterId": "lock",
        "Order": 20,
        "Match": {
          "Path": "/api/lock/{**catch-all}",
          "Methods": ["GET", "POST", "DELETE", "OPTIONS"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/lock" },
          { "PathPrefix": "/wopi/locks" }
        ]
      },
      "lock-swagger": {
        "ClusterId": "lock",
        "Order": 5,
        "Match": {
          "Path": "/lock/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/lock" }
        ]
      },

      "wopi-host-standard": {
        "ClusterId": "wopi-host",
        "Order": 30,
        "Match": {
          "Path": "/wopi/files/{**catch-all}",
          "Methods": ["GET", "POST", "OPTIONS"]
        }
      },
      "wopi-host-alias": {
        "ClusterId": "wopi-host",
        "Order": 10,
        "Match": {
          "Path": "/api/wopi/{**catch-all}",
          "Methods": ["GET", "POST", "OPTIONS"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/wopi" },
          { "PathPrefix": "/wopi/files" }
        ]
      },
      "wopi-swagger": {
        "ClusterId": "wopi-host",
        "Order": 5,
        "Match": {
          "Path": "/wopi/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/wopi" }
        ]
      },

      "openfga-api": {
        "ClusterId": "openfga",
        "Order": 20,
        "Match": {
          "Path": "/openfga/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/openfga" }
        ]
      }
    }
  }
}