# Copy to k6/.env (and fill in the values) to set environment variables for k6 tests

# Credentials for login payload (dummy/example values)
USERNAME=demo_user
PASSWORD=demo_user

# Auth endpoints (dummy/example values)
AUTH_BASE_HTTPS=https://example.com:PORT
AUTH_BASE_HTTP=http://example.com:PORT

# Optional: sleep between runs
SLEEP_BETWEEN_RUNS_SECONDS=10