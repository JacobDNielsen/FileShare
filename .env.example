# Create a .env in same directory as this file and fill in the values.

# Must match the pwd used when generating the respective cert in ./.dev-certs/pfx/
DEV_SERVER_CERT_PASSWORD=   # fileshare-server.pfx  (HTTPS + mTLS server endpoints)
DEV_CLIENT_CERT_PASSWORD=   # fileshare-client.pfx (outbound mTLS client cert)

# Protocol and port used for service-to-service traffic inside Docker.
# Three modes are supported:

# --- HTTP mode (default) ---------------------------------------------------------------
# INTERNAL_SERVICE_SCHEME=http
# INTERNAL_SERVICE_PORT=8080
# INTERNAL_SERVICE_USE_MTLS=false

# --- HTTPS mode ---------------------------------------------------------------
# INTERNAL_SERVICE_SCHEME=https
# INTERNAL_SERVICE_PORT=8443
# INTERNAL_SERVICE_USE_MTLS=false

# --- mTLS mode (requires client cert — see docs/https-certificate.md) ---------------------
INTERNAL_SERVICE_SCHEME=https
INTERNAL_SERVICE_PORT=9443
INTERNAL_SERVICE_USE_MTLS=true
